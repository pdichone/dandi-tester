# Copy to .env.local for local development. Do not commit real keys.

# NextAuth (required for app to boot)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Supabase (project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI (required for GitHub summarizer AI)
OPENAI_API_KEY=

# Optional: for Google sign-in
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Create API keys without signing in (Overview → Create New Key). Set to true to enable.
ALLOW_ANON_API_KEYS=true

# If you get Unauthorized when creating a key: run the INSERT in supabase-schema.sql (dev user),
# then in Supabase Table Editor → users → copy the id of dev@local.dev and set it here:
# DEV_USER_ID=<paste-uuid-here>

# Optional: dev user email (default dev@local.dev)
# DEV_USER_EMAIL=dev@local.dev
